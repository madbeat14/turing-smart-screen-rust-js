{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Turing Smart Screen",
  "version": "0.1.0",
  "identifier": "com.turing-smart-screen.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: https://ipc.localhost"
    },
    "windows": [
      {
        "title": "Turing Smart Screen",
        "width": 480,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "label": "monitor"
      }
    ]
  },
  "bundle": {
    "resources": [
      "external/lhm/*"
    ]
  }
}
